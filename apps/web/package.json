{
  "name": "joby-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:smoke": "next dev --hostname 127.0.0.1 -p 13000",
    "build": "next build",
    "start": "next start -p 3000",
    "start:smoke": "next start --hostname 127.0.0.1 -p 13000",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "e2e:install": "playwright install chromium",
    "e2e:smoke": "playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0"
  }
}
